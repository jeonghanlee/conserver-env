[Unit]
Description=conserver - Multi-user IOC console server
Documentation=@DOCURL@
After=network.target

[Service]
User=conserver
Group=conserver
ExecStart=@INSTALL_LOCATION@/sbin/conserver -n -d -C /etc/conserver.cf
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
